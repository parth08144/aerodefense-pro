<%- include('partials/header') %>
<link rel="stylesheet" href="/css/auth.css">
<div class="auth-page">
    <div class="bg-grid"></div>
    <div class="auth-card glass-panel">
        <h1 class="text-cyan">ENLIST</h1>
        <div class="auth-subtitle">CREATE OPERATOR CREDENTIALS</div>
        <div class="auth-status" id="authStatus"></div>
        <form id="signupForm" onsubmit="return handleSignup(event)">
            <div class="form-group"><label>CALLSIGN (USERNAME)</label><input type="text" id="username" class="form-control" placeholder="Choose callsign..." required minlength="3"></div>
            <div class="form-group"><label>FULL DESIGNATION</label><input type="text" id="fullname" class="form-control" placeholder="Full name..."></div>
            <div class="form-group"><label>EMAIL / FREQ</label><input type="email" id="email" class="form-control" placeholder="operator@aerodefense.com" required></div>
            <div class="form-group"><label>PASSWORD / CIPHER</label><input type="password" id="password" class="form-control" placeholder="Min 6 characters..." required minlength="6" oninput="checkStrength(this.value)">
                <div class="password-strength"><div class="strength-fill" id="strengthFill"></div></div>
            </div>
            <button type="submit" class="btn btn-primary btn-block btn-lg"><i class="fa-solid fa-user-plus"></i> CREATE ACCOUNT</button>
        </form>
        <div class="auth-footer">Already enlisted? <a href="/login">LOGIN</a></div>
    </div>
</div>
<script>
function checkStrength(pw) {
    const fill = document.getElementById('strengthFill');
    let s = 0; if(pw.length>=6) s++; if(pw.length>=10) s++; if(/[A-Z]/.test(pw)&&/[0-9]/.test(pw)) s++;
    fill.style.width = ['0%','33%','66%','100%'][s];
    fill.className = 'strength-fill ' + ['','strength-weak','strength-medium','strength-strong'][s];
}
async function handleSignup(e) {
    e.preventDefault();
    const status = document.getElementById('authStatus');
    status.className = 'auth-status show'; status.textContent = 'CREATING CREDENTIALS...';
    try {
        const res = await fetch('/api/auth/signup', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({ username:document.getElementById('username').value, full_name:document.getElementById('fullname').value, email:document.getElementById('email').value, password:document.getElementById('password').value })});
        const data = await res.json();
        if (data.success) { status.textContent = 'ACCOUNT CREATED — WELCOME ABOARD'; status.classList.remove('error'); setTimeout(()=>window.location='/',800); }
        else { status.textContent = data.error; status.classList.add('error'); }
    } catch { status.textContent = 'CONNECTION FAILED'; status.classList.add('error'); }
    return false;
}
</script>
<%- include('partials/footer') %>
